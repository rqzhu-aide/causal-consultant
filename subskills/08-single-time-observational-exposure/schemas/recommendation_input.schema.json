{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SingleTimeObservationalExposureRecommendationInput",
  "type": "object",
  "properties": {
    "exposure_timing": {
      "type": "string",
      "enum": ["baseline", "pre_outcome", "post_outcome", "time_varying", "unknown"]
    },
    "exposure_type": {
      "type": "string",
      "enum": ["binary", "multi_level", "continuous", "ordinal", "unknown"]
    },
    "target_trial_defined": {"type": ["boolean", "null"]},
    "estimand": {
      "type": "string",
      "enum": ["ate", "att", "atc", "overlap_population", "risk_difference", "risk_ratio", "odds_ratio", "mean_difference", "unknown"]
    },
    "data_source": {
      "type": "string",
      "enum": ["cohort", "registry", "ehr", "claims", "survey", "case_control", "cross_sectional", "unknown", "other"]
    },
    "confounder_status": {
      "type": "string",
      "enum": ["strong", "partial", "weak", "unknown"]
    },
    "overlap_status": {
      "type": "string",
      "enum": ["good", "limited", "poor", "unknown"]
    },
    "missingness_status": {
      "type": "string",
      "enum": ["none", "limited", "moderate", "severe", "unknown"]
    },
    "selection_risk": {
      "type": "string",
      "enum": ["low", "moderate", "high", "unknown"]
    },
    "outcome_type": {
      "type": "string",
      "enum": ["continuous", "binary", "count", "survival_time", "competing_risk", "unknown"]
    },
    "sample_size": {"type": ["integer", "null"], "minimum": 0},
    "n_covariates": {"type": ["integer", "null"], "minimum": 0},
    "high_dimensional": {"type": ["boolean", "null"]},
    "needs_interpretability": {"type": ["boolean", "null"]},
    "unmeasured_confounding_concern": {"type": ["boolean", "null"]},
    "has_negative_controls": {"type": ["boolean", "null"]},
    "language": {
      "type": "string",
      "enum": ["r", "python", "either", "unknown"]
    }
  },
  "required": [
    "exposure_timing",
    "exposure_type",
    "estimand",
    "data_source",
    "confounder_status",
    "overlap_status",
    "missingness_status",
    "selection_risk",
    "outcome_type",
    "language"
  ]
}
