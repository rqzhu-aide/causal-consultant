{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "did_event_study_recommendation_input",
  "type": "object",
  "properties": {
    "data_structure": {
      "type": "string",
      "enum": ["two_by_two", "panel", "unbalanced_panel", "repeated_cross_section", "aggregate_time_series", "unknown", "other"]
    },
    "treatment_path": {
      "type": "string",
      "enum": ["single_cohort", "staggered_absorbing", "reversible", "repeated", "continuous_intensity", "multiple_treatments", "unclear", "unknown", "other"]
    },
    "estimand": {
      "type": "string",
      "enum": ["att", "group_time_att", "event_time_effect", "cohort_specific", "aggregate_att", "dynamic_effect", "synthetic_did_att", "dose_or_intensity", "prediction_nuisance", "unknown", "other"]
    },
    "comparison_group": {
      "type": "string",
      "enum": ["never_treated", "not_yet_treated", "selected_controls", "synthetic_controls", "earlier_later_cohorts", "unclear", "none", "unknown"]
    },
    "has_never_treated": {"type": ["boolean", "null"]},
    "pre_periods": {"type": ["integer", "null"], "minimum": 0},
    "post_periods": {"type": ["integer", "null"], "minimum": 0},
    "anticipation_risk": {"type": "string", "enum": ["low", "moderate", "high", "unknown"]},
    "spillover_risk": {"type": "string", "enum": ["low", "moderate", "high", "unknown"]},
    "composition_risk": {"type": "string", "enum": ["low", "moderate", "high", "unknown"]},
    "treatment_reversal": {"type": "boolean"},
    "multiple_treatments": {"type": "boolean"},
    "continuous_or_intensity_treatment": {"type": "boolean"},
    "needs_covariates": {"type": "boolean"},
    "needs_dynamic_effects": {"type": "boolean"},
    "few_clusters": {"type": "boolean"},
    "cluster_level": {"type": "string"},
    "sample_size": {"type": ["integer", "null"], "minimum": 0},
    "n_units": {"type": ["integer", "null"], "minimum": 0},
    "n_treated_units": {"type": ["integer", "null"], "minimum": 0},
    "n_time_periods": {"type": ["integer", "null"], "minimum": 0},
    "language": {
      "type": "string",
      "enum": ["r", "python", "stata", "either", "unknown"]
    }
  },
  "additionalProperties": true
}
