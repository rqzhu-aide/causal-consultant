{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "regression_discontinuity_recommendation_input",
  "type": "object",
  "properties": {
    "design_variant": {
      "type": "string",
      "enum": ["sharp_rd", "fuzzy_rd", "regression_kink", "geographic_rd", "time_cutoff_rd", "multiple_cutoff_rd", "local_randomization_rd", "unknown", "other"]
    },
    "running_variable_type": {
      "type": "string",
      "enum": ["continuous", "discrete", "rank", "score", "date_time", "geographic_distance", "multidimensional", "unknown", "other"]
    },
    "cutoff_known": {"type": ["boolean", "null"]},
    "pre_specified_cutoff": {"type": ["boolean", "null"]},
    "treatment_jump_status": {
      "type": "string",
      "enum": ["sharp", "fuzzy", "kink", "no_jump", "unknown", "other"]
    },
    "target_population_scope": {
      "type": "string",
      "enum": ["local_cutoff", "near_cutoff_window", "broad_population", "unknown", "other"]
    },
    "manipulation_risk": {"type": "string", "enum": ["low", "moderate", "high", "unknown"]},
    "density_check_status": {"type": "string", "enum": ["passed", "failed", "not_run", "not_applicable", "unknown"]},
    "covariate_continuity_status": {"type": "string", "enum": ["passed", "failed", "not_run", "unknown"]},
    "bandwidth_support": {"type": "string", "enum": ["adequate", "thin", "very_thin", "unknown"]},
    "simultaneous_policy_risk": {"type": "string", "enum": ["low", "moderate", "high", "unknown"]},
    "heaping_risk": {"type": "string", "enum": ["low", "moderate", "high", "unknown"]},
    "fuzzy_compliance": {"type": "boolean"},
    "geographic_or_time_cutoff": {"type": "boolean"},
    "local_randomization_candidate": {"type": "boolean"},
    "discrete_score": {"type": "boolean"},
    "clustered": {"type": "boolean"},
    "multiple_cutoffs": {"type": "boolean"},
    "needs_power_planning": {"type": "boolean"},
    "high_order_polynomial_requested": {"type": "boolean"},
    "sample_size_near_cutoff": {"type": ["integer", "null"], "minimum": 0},
    "outcome_type": {"type": "string"},
    "language": {
      "type": "string",
      "enum": ["r", "python", "stata", "either", "unknown"]
    }
  },
  "additionalProperties": true
}
