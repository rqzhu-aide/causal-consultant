{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "synthetic_control_time_series_recommendation_input",
  "type": "object",
  "properties": {
    "data_structure": {
      "type": "string",
      "enum": ["single_series", "treated_plus_controls", "balanced_panel", "unbalanced_panel", "staggered_panel", "unknown", "other"]
    },
    "treated_units": {"type": ["integer", "null"], "minimum": 0},
    "donor_pool_status": {
      "type": "string",
      "enum": ["credible", "limited", "contaminated", "none", "unknown"]
    },
    "pre_periods": {"type": ["integer", "null"], "minimum": 0},
    "post_periods": {"type": ["integer", "null"], "minimum": 0},
    "pre_fit_status": {
      "type": "string",
      "enum": ["good", "imperfect", "poor", "unknown", "not_applicable"]
    },
    "intervention_timing": {
      "type": "string",
      "enum": ["sharp", "phase_in", "ambiguous", "multiple_dates", "unknown"]
    },
    "anticipation_risk": {"type": "string", "enum": ["low", "moderate", "high", "unknown"]},
    "spillover_risk": {"type": "string", "enum": ["low", "moderate", "high", "unknown"]},
    "concurrent_shock_risk": {"type": "string", "enum": ["low", "moderate", "high", "unknown"]},
    "seasonality_risk": {"type": "string", "enum": ["low", "moderate", "high", "unknown"]},
    "needs_synthetic_did": {"type": "boolean"},
    "needs_bsts": {"type": "boolean"},
    "no_donor_pool": {"type": "boolean"},
    "multiple_treated_periods": {"type": "boolean"},
    "outcome_frequency": {"type": "string"},
    "language": {
      "type": "string",
      "enum": ["r", "python", "stata", "either", "unknown"]
    }
  },
  "additionalProperties": true
}
