{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CausalDiscoveryRecommendationInput",
  "type": "object",
  "properties": {
    "n_samples": {"type": ["integer", "null"], "minimum": 0},
    "n_variables": {"type": ["integer", "null"], "minimum": 0},
    "data_type": {"type": "string", "enum": ["continuous", "discrete", "mixed", "text", "unknown"]},
    "has_missing_values": {"type": ["boolean", "null"]},
    "is_iid": {"type": ["boolean", "null"]},
    "is_time_series": {"type": ["boolean", "null"]},
    "has_hidden_confounders": {"type": "string", "enum": ["yes", "no", "possible", "unknown"]},
    "needs_unique_dag": {"type": ["boolean", "null"]},
    "accepts_cpdag_or_pag": {"type": ["boolean", "null"]},
    "has_interventions": {"type": ["boolean", "null"]},
    "has_background_knowledge": {"type": ["boolean", "null"]},
    "target_variable": {"type": ["string", "null"]},
    "language": {"type": "string", "enum": ["python", "r", "java", "unknown"]}
  },
  "required": ["data_type", "has_hidden_confounders", "language"]
}
