{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PointTreatmentRuleRecommendationInput",
  "type": "object",
  "properties": {
    "decision_timing": {
      "type": "string",
      "enum": ["single_point", "repeated", "unknown"]
    },
    "action_type": {
      "type": "string",
      "enum": ["binary", "multi_action", "continuous_or_dose", "unknown"]
    },
    "n_actions": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "target": {
      "type": "string",
      "enum": ["deployable_rule", "ranking", "existing_rule_evaluation", "budgeted_allocation", "subgroup_rule", "unknown"]
    },
    "design_route": {
      "type": "string",
      "enum": ["randomized", "observational_unconfounded", "instrumental_variable", "regression_discontinuity", "longitudinal", "unknown", "other"]
    },
    "data_source": {
      "type": "string",
      "enum": ["randomized_trial", "observational", "logged_policy", "unknown"]
    },
    "outcome_type": {
      "type": "string",
      "enum": ["continuous", "binary", "survival_time", "count", "utility_composite", "unknown"]
    },
    "known_propensity": {
      "type": ["boolean", "null"]
    },
    "estimated_propensity_available": {
      "type": ["boolean", "null"]
    },
    "overlap_status": {
      "type": "string",
      "enum": ["good", "limited", "poor", "unknown"]
    },
    "need_interpretability": {
      "type": "string",
      "enum": ["high", "moderate", "low", "unknown"]
    },
    "has_budget_or_capacity_constraint": {
      "type": ["boolean", "null"]
    },
    "has_cost_or_harm_model": {
      "type": ["boolean", "null"]
    },
    "language": {
      "type": "string",
      "enum": ["r", "python", "either", "unknown"]
    },
    "n_samples": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "n_features": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "high_stakes": {
      "type": ["boolean", "null"]
    },
    "has_holdout_or_crossfit_plan": {
      "type": ["boolean", "null"]
    }
  },
  "required": ["decision_timing", "action_type", "target", "design_route", "data_source", "outcome_type", "language"]
}
