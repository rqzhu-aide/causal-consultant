{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MediationRecommendationInput",
  "type": "object",
  "properties": {
    "target": {
      "type": "string",
      "enum": ["controlled_direct", "natural_direct_indirect", "interventional_direct_indirect", "separable_effect", "path_specific", "descriptive_pathway", "unknown"]
    },
    "design_route": {
      "type": "string",
      "enum": ["randomized", "observational_unconfounded", "instrumental_variable", "regression_discontinuity", "difference_in_differences", "longitudinal", "unknown", "other"]
    },
    "data_source": {
      "type": "string",
      "enum": ["randomized_trial", "observational", "panel", "registry", "unknown"]
    },
    "exposure_type": {
      "type": "string",
      "enum": ["binary", "multi_action", "continuous", "time_varying", "unknown"]
    },
    "mediator_type": {
      "type": "string",
      "enum": ["continuous", "binary", "categorical", "count", "time_varying", "latent_construct", "unknown"]
    },
    "outcome_type": {
      "type": "string",
      "enum": ["continuous", "binary", "survival_time", "count", "ordinal", "unknown"]
    },
    "mediator_count": {
      "type": "string",
      "enum": ["single", "multiple_ordered", "multiple_unordered", "high_dimensional", "unknown"]
    },
    "exposure_precedes_mediator": {
      "type": ["boolean", "null"]
    },
    "mediator_precedes_outcome": {
      "type": ["boolean", "null"]
    },
    "mediator_intervention_meaningful": {
      "type": "string",
      "enum": ["yes", "no", "unclear", "not_required", "unknown"]
    },
    "mediator_outcome_confounding_status": {
      "type": "string",
      "enum": ["measured", "partially_measured", "unmeasured", "unknown"]
    },
    "has_exposure_induced_mediator_outcome_confounder": {
      "type": "string",
      "enum": ["yes", "no", "possible", "unknown"]
    },
    "need_sensitivity_analysis": {
      "type": ["boolean", "null"]
    },
    "language": {
      "type": "string",
      "enum": ["r", "python", "either", "unknown"]
    },
    "high_stakes": {
      "type": ["boolean", "null"]
    }
  },
  "required": [
    "target",
    "design_route",
    "data_source",
    "exposure_type",
    "mediator_type",
    "outcome_type",
    "mediator_count",
    "language"
  ]
}
