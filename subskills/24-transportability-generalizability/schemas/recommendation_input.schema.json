{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TransportabilityRecommendationInput",
  "type": "object",
  "properties": {
    "target": {
      "type": "string",
      "enum": ["generalizability", "transportability", "trial_to_target", "site_transport", "meta_transport", "external_validity_assessment", "unknown"]
    },
    "source_design": {
      "type": "string",
      "enum": ["randomized_trial", "observational", "multi_site", "published_estimate_only", "unknown"]
    },
    "source_validity_status": {
      "type": "string",
      "enum": ["plausible", "questionable", "blocked", "unknown"]
    },
    "target_data": {
      "type": "string",
      "enum": ["individual_covariates", "aggregate_margins", "codebook_only", "none", "unknown"]
    },
    "effect_modifier_status": {
      "type": "string",
      "enum": ["observed", "partially_observed", "missing", "unknown"]
    },
    "overlap_status": {
      "type": "string",
      "enum": ["good", "limited", "poor", "unknown"]
    },
    "treatment_version_match": {
      "type": "string",
      "enum": ["same", "minor_difference", "major_difference", "unknown"]
    },
    "outcome_version_match": {
      "type": "string",
      "enum": ["same", "minor_difference", "major_difference", "unknown"]
    },
    "site_context_difference": {
      "type": "string",
      "enum": ["low", "moderate", "high", "unknown"]
    },
    "n_source": {"type": ["integer", "null"], "minimum": 0},
    "n_target": {"type": ["integer", "null"], "minimum": 0},
    "language": {
      "type": "string",
      "enum": ["r", "python", "either", "unknown"]
    },
    "has_multiple_sites": {"type": ["boolean", "null"]}
  },
  "required": ["target", "source_design", "source_validity_status", "target_data", "effect_modifier_status", "overlap_status", "treatment_version_match", "outcome_version_match", "language"]
}
