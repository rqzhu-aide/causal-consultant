{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DynamicTreatmentPolicyRecommendationInput",
  "type": "object",
  "properties": {
    "target": {
      "type": "string",
      "enum": ["regime_comparison", "dynamic_regime_value", "learned_dynamic_regime", "smart_analysis", "longitudinal_mtp", "exploratory_decision_support", "unknown"]
    },
    "design_route": {
      "type": "string",
      "enum": ["sequential_randomized", "smart_trial", "observational_longitudinal", "logged_policy", "unknown", "other"]
    },
    "data_source": {
      "type": "string",
      "enum": ["smart_trial", "randomized_trial", "observational", "logged_policy", "registry", "unknown"]
    },
    "decision_points": {"type": ["integer", "null"], "minimum": 0},
    "history_status": {
      "type": "string",
      "enum": ["reconstructible", "partially_reconstructible", "not_reconstructible", "unknown"]
    },
    "action_support_status": {
      "type": "string",
      "enum": ["good", "limited", "poor", "unknown"]
    },
    "time_varying_confounding": {
      "type": "string",
      "enum": ["absent", "present", "possible", "unknown"]
    },
    "censoring_status": {
      "type": "string",
      "enum": ["none", "low", "moderate", "severe", "unknown"]
    },
    "value_target": {
      "type": "string",
      "enum": ["continuous_outcome", "binary_outcome", "survival_time", "utility", "cost_harm_composite", "unknown"]
    },
    "need_interpretability": {
      "type": "string",
      "enum": ["high", "moderate", "low", "unknown"]
    },
    "language": {
      "type": "string",
      "enum": ["r", "python", "either", "unknown"]
    },
    "has_known_randomization_or_logging_probabilities": {"type": ["boolean", "null"]},
    "has_holdout_or_crossfit_plan": {"type": ["boolean", "null"]},
    "high_stakes": {"type": ["boolean", "null"]}
  },
  "required": ["target", "design_route", "data_source", "history_status", "action_support_status", "time_varying_confounding", "censoring_status", "value_target", "language"]
}
