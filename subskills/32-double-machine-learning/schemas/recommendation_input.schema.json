{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DoubleMachineLearningRecommendationInput",
  "type": "object",
  "properties": {
    "design_route": {
      "type": "string",
      "enum": ["single_time_observational", "randomized", "longitudinal", "instrumental_variable", "transportability", "survival", "unknown", "other"]
    },
    "target_model": {
      "type": "string",
      "enum": ["plr", "irm", "pliv", "iivm", "cate_forest", "r_learner", "dr_learner", "nuisance_plugin", "unknown"]
    },
    "estimand": {
      "type": "string",
      "enum": ["ate", "att", "cate", "blp", "iv_late", "policy_score", "nuisance_only", "unknown"]
    },
    "treatment_type": {
      "type": "string",
      "enum": ["binary", "continuous", "multi_arm", "instrumented", "time_varying", "unknown"]
    },
    "outcome_type": {
      "type": "string",
      "enum": ["continuous", "binary", "count", "survival_time", "unknown"]
    },
    "feature_status": {
      "type": "string",
      "enum": ["valid_pre_treatment", "mixed_or_unclear", "contains_post_treatment", "unknown"]
    },
    "high_dimensional": {"type": ["boolean", "null"]},
    "sample_size": {"type": ["integer", "null"], "minimum": 0},
    "n_features": {"type": ["integer", "null"], "minimum": 0},
    "positivity_status": {
      "type": "string",
      "enum": ["good", "limited", "poor", "unknown"]
    },
    "needs_inference": {"type": ["boolean", "null"]},
    "clustered_or_grouped": {"type": ["boolean", "null"]},
    "heterogeneity_target": {"type": ["boolean", "null"]},
    "policy_target": {"type": ["boolean", "null"]},
    "language": {
      "type": "string",
      "enum": ["r", "python", "either", "unknown"]
    }
  },
  "required": [
    "design_route",
    "target_model",
    "estimand",
    "treatment_type",
    "outcome_type",
    "feature_status",
    "positivity_status",
    "language"
  ]
}
