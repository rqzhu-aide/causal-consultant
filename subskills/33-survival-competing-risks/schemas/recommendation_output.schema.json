{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "survival_competing_risks_recommendation_output",
  "type": "object",
  "required": [
    "readiness",
    "target_lane",
    "top_choice",
    "software_options",
    "diagnostics",
    "caveats",
    "activate_other_subskills",
    "report_support",
    "recommended_next_action"
  ],
  "properties": {
    "readiness": {
      "type": "string",
      "enum": ["plan_ready", "candidate_only", "diagnostics_needed", "blocked"]
    },
    "target_lane": {"type": "string"},
    "top_choice": {"type": "string"},
    "software_options": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["package", "language", "when_to_use"],
        "properties": {
          "package": {"type": "string"},
          "language": {"type": "string"},
          "when_to_use": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "required_clarifications": {
      "type": "array",
      "items": {"type": "string"}
    },
    "diagnostics": {
      "type": "array",
      "items": {"type": "string"}
    },
    "caveats": {
      "type": "array",
      "items": {"type": "string"}
    },
    "activate_other_subskills": {
      "type": "array",
      "items": {"type": "string"}
    },
    "report_support": {
      "type": "array",
      "items": {"type": "string"}
    },
    "recommended_next_action": {"type": "string"}
  },
  "additionalProperties": false
}
